{
  "manifest_version": 3,
  "name": "SanrakshAN Audio Shield",
  "version": "1.0.0",
  "description": "Real-time audio deepfake detection for browser calls and meetings.",

  "permissions": [
    "tabCapture",
    "activeTab",
    "storage",
    "scripting"
  ],

  "host_permissions": [
    "https://sanrakshan-api.onrender.com/*",
    "http://localhost:8000/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_badge_text": ""
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
